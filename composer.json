{
    "name": "hypersender/distributed-tracing",
    "description": "Distributed request tracing for Hypersender services — s-request-id and instance context injection.",
    "keywords": [
        "hypersender",
        "laravel",
        "distributed-tracing",
        "s-request-id"
    ],
    "homepage": "https://github.com/hypersender/distributed-tracing",
    "license": "MIT",
    "authors": [
        {
            "name": "Hypersender",
            "email": "info@hypersender.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "suggest": {
        "sentry/sentry-laravel": "Auto-tag Sentry events with s-request-id and instance context"
    },
    "autoload": {
        "psr-4": {
            "Hypersender\\DistributedTracing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hypersender\\DistributedTracing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hypersender\\DistributedTracing\\DistributedTracingServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
